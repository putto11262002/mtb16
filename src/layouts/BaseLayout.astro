---
import type { AstroBuiltinAttributes } from "astro";

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title ? `${title} | MBT 16` : "MBT 16 | Army Unit News & Resources"}</title>
    <meta
      name="description"
      content={description || "MBT 16 official site: news, announcements, leadership info, and downloadable resources."}
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="stylesheet" href="/src/styles/global.css" />
  </head>
  <body class="dark bg-background text-foreground">
    <header
      class="bg-gradient-to-r from-primary to-secondary text-primary-foreground py-4 shadow-md"
    >
      <div class="container mx-auto flex justify-between items-center px-4">
        <a href="/" class="text-2xl font-bold">MBT 16</a>
        <nav>
          <ul class="flex space-x-6">
            <li><a href="/news" class="hover:underline transition-all duration-300">News</a></li>
            <li>
              <a href="/announcements" class="hover:underline transition-all duration-300"
                >Announcements</a>
            </li>
            <li>
              <a href="/about-us" class="hover:underline transition-all duration-300">About Us</a>
            </li>
            <li>
              <a href="/contact" class="hover:underline transition-all duration-300">Contact</a>
            </li>
          </ul>
        </nav>
      </div>
    </header>
    
    <main>
      <slot />
    </main>
    
    <footer class="bg-gradient-to-r from-primary to-secondary text-primary-foreground py-12 mt-16">
      <div class="container mx-auto text-center px-4">
        <p class="text-lg">&copy; {new Date().getFullYear()} MBT 16. All rights reserved.</p>
        <ul class="flex justify-center space-x-8 mt-4">
          <li>
            <a href="/privacy-policy" class="hover:underline transition-all duration-300"
              >Privacy Policy</a>
          </li>
          <li>
            <a href="/terms-of-service" class="hover:underline transition-all duration-300"
              >Terms of Service</a>
          </li>
        </ul>
      </div>
    </footer>
  </body>
</html>