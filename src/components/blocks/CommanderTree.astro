---
// src/components/blocks/CommanderTree.astro
import type { Commander } from '@/lib/mock-commanders';
import CommanderCard from './CommanderCard.astro';

interface Props {
  node: Commander;
}

const { node } = Astro.props;
---

<div class="flex flex-col items-center text-center">
  <!-- Render the current commander -->
  <div class="mb-8">
    <CommanderCard commander={node} />
  </div>

  <!-- Render subordinates if they exist -->
  {
    node.subordinates &&
      node.subordinates.length > 0 && (
        <div class="w-full flex justify-center">
          <div class="flex flex-wrap justify-center gap-x-16 gap-y-12 relative before:content-[''] before:absolute before:bg-primary before:w-full before:h-px before:top-[-2rem]">
            {node.subordinates.map((subordinate) => (
              <div class="relative before:content-[''] before:absolute before:bg-primary before:w-px before:h-8 before:top-[-2rem] before:left-1/2 before:-translate-x-1/2">
                <Astro.self node={subordinate} />
              </div>
            ))}
          </div>
        </div>
      )
  }
</div>
