---
import { Sheet, SheetContent, SheetTrigger } from "@/components/ui/sheet";
---

<Sheet>
  <SheetTrigger as="button" class="md:hidden text-primary-foreground">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-menu">
      <line x1="4" x2="20" y1="12" y2="12"></line>
      <line x1="4" x2="20" y1="6" y2="6"></line>
      <line x1="4" x2="20" y1="18" y2="18"></line>
    </svg>
    <span class="sr-only">เปิดเมนู</span>
  </SheetTrigger>
  <SheetContent side="right" class="w-[300px] sm:w-[400px] bg-background">
    <div class="flex flex-col space-y-4 py-4">
      <a href="/" class="text-2xl font-bold text-foreground">MBT 16</a>
      
      <nav class="flex flex-col space-y-4 mt-8">
        <a href="/news" class="text-foreground hover:text-accent-foreground py-2 px-4 rounded-md hover:bg-accent transition-colors">
          ข่าวสาร
        </a>
        
        <a href="/announcements" class="text-foreground hover:text-accent-foreground py-2 px-4 rounded-md hover:bg-accent transition-colors">
          ประกาศ
        </a>
        
        <div class="space-y-2">
          <div class="text-foreground font-medium py-2 px-4">เกี่ยวกับเรา</div>
          <div class="flex flex-col pl-4 space-y-2">
            <a href="/about-us" class="text-foreground hover:text-accent-foreground py-2 px-4 rounded-md hover:bg-accent transition-colors">
              ประวัติหน่วย
            </a>
            <a href="/about-us/leadership" class="text-foreground hover:text-accent-foreground py-2 px-4 rounded-md hover:bg-accent transition-colors">
              ผู้บัญชาการและผู้นำ
            </a>
          </div>
        </div>
        
        <div class="space-y-2">
          <div class="text-foreground font-medium py-2 px-4">ไดเรกทอรี</div>
          <div class="flex flex-col pl-4 space-y-2">
            <a href="/directory/internal" class="text-foreground hover:text-accent-foreground py-2 px-4 rounded-md hover:bg-accent transition-colors">
              หน่วยย่อยและแผนกภายใน
            </a>
            <a href="/directory/external" class="text-foreground hover:text-accent-foreground py-2 px-4 rounded-md hover:bg-accent transition-colors">
              เครือข่ายภายนอกและความร่วมมือ
            </a>
          </div>
        </div>
        
        <a href="/document-library" class="text-foreground hover:text-accent-foreground py-2 px-4 rounded-md hover:bg-accent transition-colors">
          คลังเอกสาร
        </a>
        
        <a href="/contact" class="text-foreground hover:text-accent-foreground py-2 px-4 rounded-md hover:bg-accent transition-colors">
          ติดต่อ
        </a>
      </nav>
    </div>
  </SheetContent>
</Sheet>