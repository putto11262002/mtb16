---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Directory';
const description = 'Find contact information for MBT 16 internal units and external partners.';
---

<BaseLayout {title} {description}>
  <div class="container mx-auto py-16 px-4">
    <h1 class="text-4xl font-bold mb-8 text-center">Directory</h1>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
      <div class="bg-muted rounded-xl p-8 text-center">
        <h2 class="text-2xl font-bold mb-4">Internal Units</h2>
        <p class="mb-6">
          Contact information for internal sub-units and departments within MBT 16.
        </p>
        <a
          href="/directory/internal"
          class="inline-block bg-primary text-primary-foreground px-6 py-3 rounded-lg font-medium hover:bg-primary/90 transition-colors"
        >
          View Internal Directory
        </a>
      </div>

      <div class="bg-muted rounded-xl p-8 text-center">
        <h2 class="text-2xl font-bold mb-4">External Partners</h2>
        <p class="mb-6">Contact information for external organizations and partnerships.</p>
        <a
          href="/directory/external"
          class="inline-block bg-primary text-primary-foreground px-6 py-3 rounded-lg font-medium hover:bg-primary/90 transition-colors"
        >
          View External Directory
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
