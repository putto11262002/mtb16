---
import Layout from '../layouts/main.astro';
---

<Layout title="Welcome to the Landing Page">
  <main>
    <section id="hero" class="relative h-[60vh] flex items-center justify-center text-center bg-cover bg-center" style="background-image: url('/placeholder-hero.jpg');">
      <div class="absolute inset-0 bg-black opacity-50"></div>
      <div class="relative z-10 text-white">
        {/* TODO: asset request for unit crest/logo */}
        <img src="/placeholder-logo.png" alt="Unit Logo" class="mx-auto mb-4 h-24 w-24" />
        <h1 class="text-5xl font-bold mb-2">Unit Name</h1>
        <p class="text-xl">Motto or mission tagline</p>
      </div>
    </section>
    
    <section id="news-activities" class="container mx-auto py-12">
      <h2 class="text-3xl font-bold text-center mb-8">ข่าวสารและกิจกรรม</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {/* News Item 1 */}
        <div class="bg-card text-card-foreground rounded-lg shadow-md overflow-hidden">
          {/* TODO: asset request for news thumbnail */}
          <img src="/placeholder-news.jpg" alt="News Thumbnail" class="w-full h-48 object-cover"/>
          <div class="p-6">
            <h3 class="text-xl font-semibold mb-2">ข่าวประชาสัมพันธ์ 1</h3>
            <p class="text-muted-foreground text-sm mb-4">วันที่ 23 สิงหาคม 2568</p>
            <p class="text-foreground mb-4">รายละเอียดข่าวสั้นๆ...</p>
            <a href="#" class="text-primary hover:underline">อ่านเพิ่มเติม</a>
          </div>
        </div>
        {/* News Item 2 */}
        <div class="bg-card text-card-foreground rounded-lg shadow-md overflow-hidden">
          {/* TODO: asset request for news thumbnail */}
          <img src="/placeholder-news.jpg" alt="News Thumbnail" class="w-full h-48 object-cover"/>
          <div class="p-6">
            <h3 class="text-xl font-semibold mb-2">กิจกรรมพิเศษ 1</h3>
            <p class="text-muted-foreground text-sm mb-4">วันที่ 22 สิงหาคม 2568</p>
            <p class="text-foreground mb-4">รายละเอียดกิจกรรมสั้นๆ...</p>
            <a href="#" class="text-primary hover:underline">อ่านเพิ่มเติม</a>
          </div>
        </div>
        {/* News Item 3 */}
        <div class="bg-card text-card-foreground rounded-lg shadow-md overflow-hidden">
          {/* TODO: asset request for news thumbnail */}
          <img src="/placeholder-news.jpg" alt="News Thumbnail" class="w-full h-48 object-cover"/>
          <div class="p-6">
            <h3 class="text-xl font-semibold mb-2">ประกาศสำคัญ 1</h3>
            <p class="text-muted-foreground text-sm mb-4">วันที่ 21 สิงหาคม 2568</p>
            <p class="text-foreground mb-4">รายละเอียดประกาศสั้นๆ...</p>
            <a href="#" class="text-primary hover:underline">อ่านเพิ่มเติม</a>
          </div>
        </div>
      </div>
      <div class="text-center mt-8">
        <a href="#" class="inline-flex items-center justify-center whitespace-nowrap rounded-md text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 bg-primary text-primary-foreground hover:bg-primary/90 h-10 px-4 py-2">ดูข่าวสารทั้งหมด</a>
      </div>
    </section>
    <section id="events-announcements" class="container mx-auto py-12">
      <h2 class="text-3xl font-bold text-center mb-8">กิจกรรมและประกาศ</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {/* Recruitment Notices */}
        <div class="bg-card text-card-foreground rounded-lg shadow-md p-6 flex items-start space-x-4">
          <div class="flex-shrink-0 text-primary">
            {/* TODO: asset request for recruitment icon */}
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-user-plus"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" x2="19" y1="8" y2="14"/><line x1="22" x2="16" y1="11" y2="11"/></svg>
          </div>
          <div>
            <h3 class="text-xl font-semibold mb-2">ประกาศรับสมัคร</h3>
            <p class="text-foreground">รายละเอียดประกาศรับสมัครบุคลากรใหม่</p>
            <a href="#" class="text-primary hover:underline text-sm mt-2 block">ดูรายละเอียด</a>
          </div>
        </div>
        {/* Procurement/Tenders */}
        <div class="bg-card text-card-foreground rounded-lg shadow-md p-6 flex items-start space-x-4">
          <div class="flex-shrink-0 text-green-500">
            {/* TODO: asset request for procurement icon */}
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-clipboard-list"><rect width="8" height="4" x="8" y="2" rx="1" ry="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><path d="M12 11h4"/><path d="M12 16h4"/><path d="M8 11h.01"/><path d="M8 16h.01"/></svg>
          </div>
          <div>
            <h3 class="text-xl font-semibold mb-2">ประกาศจัดซื้อจัดจ้าง</h3>
            <p class="text-foreground">รายละเอียดประกาศการจัดซื้อจัดจ้างและประกวดราคา</p>
            <a href="#" class="text-primary hover:underline text-sm mt-2 block">ดูรายละเอียด</a>
          </div>
        </div>
        {/* Public Ceremonies */}
        <div class="bg-card text-card-foreground rounded-lg shadow-md p-6 flex items-start space-x-4">
          <div class="flex-shrink-0 text-blue-500">
            {/* TODO: asset request for ceremony icon */}
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-calendar"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
          </div>
          <div>
            <h3 class="text-xl font-semibold mb-2">พิธีสาธารณะ</h3>
            <p class="text-foreground">รายละเอียดเกี่ยวกับพิธีและกิจกรรมพิเศษต่างๆ</p>
            <a href="#" class="text-primary hover:underline text-sm mt-2 block">ดูรายละเอียด</a>
          </div>
        </div>
        {/* Special Events */}
        <div class="bg-card text-card-foreground rounded-lg shadow-md p-6 flex items-start space-x-4">
          <div class="flex-shrink-0 text-yellow-500">
            {/* TODO: asset request for special event icon */}
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-star"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          </div>
          <div>
            <h3 class="text-xl font-semibold mb-2">กิจกรรมพิเศษ</h3>
            <p class="text-foreground">รายละเอียดกิจกรรมพิเศษที่กำลังจะเกิดขึ้น</p>
            <a href="#" class="text-primary hover:underline text-sm mt-2 block">ดูรายละเอียด</a>
          </div>
        </div>
      </div>
    </section>
  </main>

</Layout>
