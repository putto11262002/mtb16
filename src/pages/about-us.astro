---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'About MBT 16 – History & Leadership';
const description = 'Learn about the mission, values, and leadership of MBT 16.';
---

<BaseLayout {title} {description}>
  <div class="container mx-auto py-16 px-4">
    <div class="text-center mb-16">
      <h1 class="text-4xl font-bold mb-4">About MBT 16</h1>
      <p class="text-xl text-muted-foreground">Our mission, values, and leadership</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 max-w-6xl mx-auto">
      <div class="bg-muted rounded-xl p-8">
        <h2 class="text-2xl font-bold mb-6">Our Mission</h2>
        <p class="mb-6">
          MBT 16 is committed to excellence in all our operations, maintaining the highest standards
          of professionalism while fostering strong relationships with our local community and
          partners.
        </p>

        <h3 class="text-xl font-bold mb-4 mt-8">Our Values</h3>
        <ul class="space-y-3">
          <li class="flex items-start">
            <span class="inline-block w-2 h-2 rounded-full bg-primary mt-2 mr-3"></span>
            <span
              ><strong>Integrity:</strong> We act with honesty and transparency in all our dealings.</span
            >
          </li>
          <li class="flex items-start">
            <span class="inline-block w-2 h-2 rounded-full bg-primary mt-2 mr-3"></span>
            <span
              ><strong>Service:</strong> We are dedicated to serving our community and nation.</span
            >
          </li>
          <li class="flex items-start">
            <span class="inline-block w-2 h-2 rounded-full bg-primary mt-2 mr-3"></span>
            <span
              ><strong>Excellence:</strong> We strive for the highest standards in everything we do.</span
            >
          </li>
          <li class="flex items-start">
            <span class="inline-block w-2 h-2 rounded-full bg-primary mt-2 mr-3"></span>
            <span><strong>Respect:</strong> We treat all individuals with dignity and respect.</span
            >
          </li>
        </ul>
      </div>

      <div class="bg-muted rounded-xl p-8">
        <h2 class="text-2xl font-bold mb-6">ประวัติหน่วย</h2>
        <div class="space-y-4">
          <div class="border-l-4 border-primary pl-4 py-1">
            <h3 class="font-bold">๓๐ เมษายน พ.ศ. ๒๔๘๔</h3>
            <p class="text-muted-foreground">
              จัดตั้งขึ้นตามข้อบังคับทหารว่าด้วยการแบ่งเขตมณฑลและจังหวัดทหาร
              ถือเป็นวันสถาปนาจังหวัดทหารบกราชบุรี
            </p>
          </div>
          <div class="border-l-4 border-primary pl-4 py-1">
            <h3 class="font-bold">๕ สิงหาคม พ.ศ. ๒๕๓๑</h3>
            <p class="text-muted-foreground">
              ปรับการจัดหน่วยตามอัตราการจัดยุทโธปกรณ์ หมายเลข ๕๑ – ๓๐๑
              เป็นหน่วยขึ้นตรงของมณฑลทหารบกที่ ๑๑
            </p>
          </div>
          <div class="border-l-4 border-primary pl-4 py-1">
            <h3 class="font-bold">๑๓ กรกฎาคม พ.ศ. ๒๕๔๑</h3>
            <p class="text-muted-foreground">
              ย้ายจากที่ตั้งเดิมมายังที่ตั้งปกติถาวรแห่งใหม่ริมถนนเพชรเกษมสายเก่า
            </p>
          </div>
          <div class="border-l-4 border-primary pl-4 py-1">
            <h3 class="font-bold">๑ เมษายน พ.ศ. ๒๕๕๒</h3>
            <p class="text-muted-foreground">
              เป็นหน่วยขึ้นตรงของมณฑลทหารบกที่ ๑๕
              รับผิดชอบ ๒ จังหวัด คือ จังหวัดราชบุรี และ จังหวัดสมุทรสงคราม
            </p>
          </div>
          <div class="border-l-4 border-primary pl-4 py-1">
            <h3 class="font-bold">๑ ตุลาคม พ.ศ. ๒๕๕๘</h3>
            <p class="text-muted-foreground">
              แปรสภาพเป็นมณฑลทหารบกที่ ๑๖ รับผิดชอบ ๓ จังหวัด คือ จังหวัดราชบุรี
              จังหวัดสมุทรสงคราม และจังหวัดสมุทรสาคร
            </p>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-16 text-center">
      <div class="bg-card border border-border rounded-xl p-8 max-w-3xl mx-auto">
        <h2 class="text-2xl font-bold mb-4">Meet Our Leadership Team</h2>
        <p class="mb-6 text-muted-foreground">
          Our leadership team brings decades of experience and expertise to guide MBT 16.
        </p>
        <a
          href="/about-us/leadership"
          class="inline-block bg-primary text-primary-foreground px-6 py-3 rounded-lg font-medium hover:bg-primary/90 transition-colors"
        >
          View Leadership Profiles
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
