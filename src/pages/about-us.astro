---
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  Card,
  CardContent,
  CardDescription,
  CardFooter,
  CardHeader,
  CardTitle,
} from '@/components/ui/card';
import { Button } from '@/components/ui/button';

const title = 'เกี่ยวกับหน่วย – ประวัติและความเป็นมา';
const description = 'เรียนรู้เกี่ยวกับภารกิจ ค่านิยม และความเป็นมาของหน่วย';
---

<BaseLayout {title} {description}>
  <div class="container mx-auto py-16 px-4">
    <div class="text-center mb-12">
      <h1 class="text-4xl font-bold mb-4">เกี่ยวกับ MBT 16</h1>
      <p class="text-xl text-muted-foreground max-w-2xl mx-auto">ภารกิจ ค่านิยม และผู้นำของเรา</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div class="md:col-span-2 space-y-8">
        <Card>
          <CardContent class="p-0">
            <div class="aspect-video bg-muted flex items-center justify-center">
              <div class="text-center text-muted-foreground">
                <div class="text-6xl mb-4">🏛️</div>
                <p class="text-sm">ภาพประกอบประวัติหน่วย</p>
                {/* Asset: history_image - see page spec */}
              </div>
            </div>
          </CardContent>
          <CardHeader>
            <CardTitle>ประวัติความเป็นมา</CardTitle>
            <CardDescription>
              มณฑลทหารบกที่ ๑๖ มีประวัติการก่อตั้งที่ยาวนานและมีคุณค่า
            </CardDescription>
          </CardHeader>
          <CardContent>
            <p class="text-sm text-muted-foreground leading-relaxed">
              จังหวัดทหารบกราชบุรี ตั้งขึ้นครั้งแรกเมื่อปี พ.ศ. ๒๔๘๔ และได้แปรสภาพเป็นมณฑลทหารบกที่
              ๑๖ ในปี พ.ศ. ๒๕๕๘ รับผิดชอบพื้นที่ ๓ จังหวัด คือ ราชบุรี สมุทรสงคราม และสมุทรสาคร
            </p>
          </CardContent>
        </Card>

        <Card>
          <CardHeader>
            <CardTitle>เหตุการณ์สำคัญ</CardTitle>
            <CardDescription>เส้นทางประวัติศาสตร์ของหน่วย</CardDescription>
          </CardHeader>
          <CardContent>
            <div class="space-y-4">
              <div class="border-l-4 border-primary pl-4 py-1">
                <h3 class="font-bold">๓๐ เมษายน พ.ศ. ๒๔๘๔</h3>
                <p class="text-muted-foreground text-sm">
                  จัดตั้งขึ้นตามข้อบังคับทหารว่าด้วยการแบ่งเขตมณฑลและจังหวัดทหาร
                  ถือเป็นวันสถาปนาจังหวัดทหารบกราชบุรี
                </p>
              </div>
              <div class="border-l-4 border-primary pl-4 py-1">
                <h3 class="font-bold">๕ สิงหาคม พ.ศ. ๒๕๓๑</h3>
                <p class="text-muted-foreground text-sm">
                  ปรับการจัดหน่วยตามอัตราการจัดยุทโธปกรณ์ หมายเลข ๕๑ – ๓๐๑
                  เป็นหน่วยขึ้นตรงของมณฑลทหารบกที่ ๑๑
                </p>
              </div>
              <div class="border-l-4 border-primary pl-4 py-1">
                <h3 class="font-bold">๑๓ กรกฎาคม พ.ศ. ๒๕๔๑</h3>
                <p class="text-muted-foreground text-sm">
                  ย้ายจากที่ตั้งเดิมมายังที่ตั้งปกติถาวรแห่งใหม่ริมถนนเพชรเกษมสายเก่า
                </p>
              </div>
              <div class="border-l-4 border-primary pl-4 py-1">
                <h3 class="font-bold">๑ ตุลาคม พ.ศ. ๒๕๕๘</h3>
                <p class="text-muted-foreground text-sm">
                  แปรสภาพเป็นมณฑลทหารบกที่ ๑๖ รับผิดชอบ ๓ จังหวัด คือ จังหวัดราชบุรี
                  จังหวัดสมุทรสงคราม และจังหวัดสมุทรสาคร
                </p>
              </div>
            </div>
          </CardContent>
        </Card>
      </div>

      <div class="space-y-8">
        <Card>
          <CardHeader>
            <CardTitle>ทำเนียบผู้บังคับบัญชา</CardTitle>
            <CardDescription>ทำความรู้จักกับทีมผู้นำหน่วยของเรา</CardDescription>
          </CardHeader>
          <CardContent>
            <p class="text-sm text-muted-foreground">
              หน่วยของเรานำโดยทีมผู้ทรงคุณวุฒิและมีประสบการณ์
            </p>
          </CardContent>
          <CardFooter>
            <a href="/about-us/leadership" class="w-full">
              <Button variant="outline" className="w-full"> ดูทำเนียบ </Button>
            </a>
          </CardFooter>
        </Card>

        <Card>
          <CardHeader>
            <CardTitle>ภารกิจหลัก</CardTitle>
            <CardDescription>บทบาทและความรับผิดชอบ</CardDescription>
          </CardHeader>
          <CardContent>
            <div class="space-y-3">
              <div class="flex items-start space-x-2">
                <div class="w-2 h-2 bg-primary rounded-full mt-2 flex-shrink-0"></div>
                <p class="text-sm text-muted-foreground">รักษาความปลอดภัยในเขตพื้นที่รับผิดชอบ</p>
              </div>
              <div class="flex items-start space-x-2">
                <div class="w-2 h-2 bg-primary rounded-full mt-2 flex-shrink-0"></div>
                <p class="text-sm text-muted-foreground">สนับสนุนการฝึกและพัฒนากำลังพล</p>
              </div>
              <div class="flex items-start space-x-2">
                <div class="w-2 h-2 bg-primary rounded-full mt-2 flex-shrink-0"></div>
                <p class="text-sm text-muted-foreground">ประสานงานกับหน่วยงานพลเรือน</p>
              </div>
            </div>
          </CardContent>
        </Card>

        <Card>
          <CardHeader>
            <CardTitle>พื้นที่รับผิดชอบ</CardTitle>
            <CardDescription>เขตดำเนินงานครอบคลุม</CardDescription>
          </CardHeader>
          <CardContent>
            <div class="space-y-2">
              <div class="text-sm font-medium">📍 จังหวัดราชบุรี</div>
              <div class="text-sm font-medium">📍 จังหวัดสมุทรสงคราม</div>
              <div class="text-sm font-medium">📍 จังหวัดสมุทรสาคร</div>
              <p class="text-xs text-muted-foreground mt-2">
                ครอบคลุมพื้นที่ทั้งหมด ๓ จังหวัด ที่ตั้งหน่วย: เลขที่ ๑๕๘ หมู่ ๑ ต.โคกหม้อ อ.เมือง
                จว.ราชบุรี
              </p>
            </div>
          </CardContent>
        </Card>
      </div>
    </div>
  </div>
</BaseLayout>
