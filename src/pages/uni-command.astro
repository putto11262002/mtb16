---
// src/pages/uni-command.astro
import BaseLayout from '@/layouts/BaseLayout.astro';
import CommanderTree from '@/components/blocks/CommanderTree.astro';
import { commandStructure } from '@/lib/mock-commanders';

const title = 'ทำเนียบผู้บังคับบัญชา';
const description = 'โครงสร้างสายการบังคับบัญชาของหน่วย';
---

<BaseLayout {title} {description}>
  <section class="container mx-auto py-16 px-4">
    <div class="text-center mb-16">
      <h1 class="text-4xl font-bold mb-4">{title}</h1>
      <p class="text-xl text-muted-foreground">{description}</p>
      <div class="w-24 h-1 bg-gradient-to-r from-primary to-secondary mx-auto rounded-full mt-4"></div>
    </div>

    <div class="overflow-x-auto p-4">
      <CommanderTree node={commandStructure} />
    </div>
  </section>
</BaseLayout>
