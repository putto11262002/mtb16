---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Document Library';
const description = 'Access important documents, forms, and resources from MBT 16.';
---

<BaseLayout {title} {description}>
  <div class="container mx-auto py-16 px-4">
    <h1 class="text-4xl font-bold mb-8 text-center">Document Library</h1>

    <div class="bg-muted rounded-xl p-8 mb-12 text-center">
      <p class="text-lg">
        The document library is currently being organized. Check back soon for downloadable
        resources.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-4xl mx-auto">
      <div class="bg-card rounded-lg p-6 border border-border">
        <h3 class="text-xl font-bold mb-3">Forms & Applications</h3>
        <p class="mb-4">Official forms and applications for various purposes.</p>
        <span class="text-muted-foreground text-sm">Coming soon</span>
      </div>

      <div class="bg-card rounded-lg p-6 border border-border">
        <h3 class="text-xl font-bold mb-3">Policies & Procedures</h3>
        <p class="mb-4">Official policies and standard operating procedures.</p>
        <span class="text-muted-foreground text-sm">Coming soon</span>
      </div>

      <div class="bg-card rounded-lg p-6 border border-border">
        <h3 class="text-xl font-bold mb-3">Reports & Publications</h3>
        <p class="mb-4">Annual reports, newsletters, and other publications.</p>
        <span class="text-muted-foreground text-sm">Coming soon</span>
      </div>
    </div>
  </div>
</BaseLayout>
