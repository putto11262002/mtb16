---
import BaseLayout from '../layouts/BaseLayout.astro';
import { announcements } from '@/lib/mock-data';

const title = 'Announcements';
const description = 'Official announcements and important notices from MBT 16.';
---

<BaseLayout {title} {description}>
  <div class="container mx-auto py-16 px-4">
    <h1 class="text-4xl font-bold mb-8 text-center">Official Announcements</h1>

    {
      announcements.length > 0 ? (
        <div class="grid gap-8 md:grid-cols-1 lg:grid-cols-2">
          {announcements.map((announcement) => (
            <div class="border p-4 rounded-lg">
              <h2 class="text-xl font-bold">{announcement.title}</h2>
              <p class="text-sm text-gray-500 mb-2">
                Published on:{' '}
                {announcement.published_at.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </p>
              <p>{announcement.content}</p>
              {announcement.author && (
                <p class="text-xs text-gray-400 mt-4">By: {announcement.author}</p>
              )}
            </div>
          ))}
        </div>
      ) : (
        <div class="bg-muted rounded-xl p-8 mb-12 text-center">
          <p class="text-lg">
            No announcements available at this time. Important notices will be posted here when
            needed.
          </p>
        </div>
      )
    }

    <div class="text-center mt-12">
      <p class="text-muted-foreground">
        Check back regularly for important updates and announcements.
      </p>
    </div>
  </div>
</BaseLayout>
