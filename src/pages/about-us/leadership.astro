---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Leadership";
const description = "Meet the leadership team of MBT 16.";
---

<BaseLayout {title} {description}>
  <div class="container mx-auto py-16 px-4">
    <h1 class="text-4xl font-bold mb-8 text-center">Unit Leadership</h1>
    
    <div class="bg-muted rounded-xl p-8 mb-12 text-center">
      <p class="text-lg">
        Leadership profiles will be available here.
      </p>
    </div>
    
    <div class="text-center">
      <a 
        href="/about-us" 
        class="inline-block bg-secondary text-secondary-foreground px-6 py-3 rounded-lg font-medium hover:bg-secondary/90 transition-colors"
      >
        Back to About Us
      </a>
    </div>
  </div>
</BaseLayout>