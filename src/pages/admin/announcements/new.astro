---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { Button } from '@/components/ui/button';

const title = 'Create New Announcement';
const description = 'Admin page to create a new announcement.';
---

<BaseLayout {title} {description}>
  <div class="container mx-auto py-16 px-4">
    <h1 class="text-4xl font-bold mb-8">Create New Announcement</h1>
    <form class="max-w-2xl mx-auto">
      <div class="grid gap-6">
        <div class="grid gap-2">
          <label for="title" class="text-lg font-semibold">Title</label>
          <input
            type="text"
            id="title"
            name="title"
            class="w-full px-4 py-2 border rounded-md bg-muted text-foreground"
            placeholder="Announcement Title"
          />
        </div>
        <div class="grid gap-2">
          <label for="content" class="text-lg font-semibold">Content</label>
          <textarea
            id="content"
            name="content"
            rows="8"
            class="w-full px-4 py-2 border rounded-md bg-muted text-foreground"
            placeholder="Full content of the announcement..."
          ></textarea>
        </div>
        <div class="grid gap-2">
          <label for="author" class="text-lg font-semibold">Author</label>
          <input
            type="text"
            id="author"
            name="author"
            class="w-full px-4 py-2 border rounded-md bg-muted text-foreground"
            placeholder="e.g., Commander's Office"
          />
        </div>
        <div class="grid gap-2">
          <label for="tags" class="text-lg font-semibold">Tags</label>
          <input
            type="text"
            id="tags"
            name="tags"
            class="w-full px-4 py-2 border rounded-md bg-muted text-foreground"
            placeholder="Comma-separated tags, e.g., official, safety"
          />
          <p class="text-sm text-muted-foreground">
            Provide tags separated by commas.
          </p>
        </div>
        <div class="flex justify-end">
            <Button type="submit">Create Announcement</Button>
        </div>
      </div>
    </form>
  </div>
</BaseLayout>
