{
	"$schema": "https://opencode.ai/config.json",
	"theme": "opencode",
	"model": "qwen/qwen3-coder",
	"autoupdate": true,
	"provider": {
		"openrouter": {
			"models": {
				"qwen/qwen3-coder": {
					"options": {
						"provider": {
							"order": [
								"deepinfra/fp4"
							],
							"allow_fallbacks": false
						}
					}
				}
			}
		}
	},
	"mcp": {
		"shadcn": {
			"type": "local",
			"command": [
				"npx",
				"@jpisnice/shadcn-ui-mcp-server"
			],
			"enabled": true,
			"environment": {
				"GITHUB_PERSONAL_ACCESS_TOKEN": "{env:GITHUB_PERSONAL_ACCESS_TOKEN}"
			}
		}
	}
}
